{
  "manifest_version": 3,
  "name": "GitHub SNA – Social Network Analyzer",
  "version": "1.0.0",
  "description": "Analyze GitHub collaboration networks using graph algorithms (BFS, PageRank, Union-Find)",
  "permissions": ["storage", "sidePanel", "windows", "contextMenus"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "host_permissions": ["https://api.github.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "GitHub SNA"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
